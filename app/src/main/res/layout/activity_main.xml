<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#182620">

    <!-- Pairing screen shown until admin assigns this display to a venue -->
    <LinearLayout
        android:id="@+id/pairing_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#182620"
        android:padding="48dp"
        android:visibility="visible">

        <!-- JJJK Logo -->
        <ImageView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:src="@drawable/jjjk_logo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_marginBottom="20dp"/>

        <!-- Green accent divider -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="#6fd98c"
            android:layout_marginBottom="20dp"/>

        <!-- App name -->
        <TextView
            android:text="VenueOS Player"
            android:textColor="#f0dfa0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"/>

        <!-- Pairing code label -->
        <TextView
            android:text="PAIRING CODE"
            android:textColor="#6c7d72"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Pairing code value — outlined card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pairing_code_bg"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:id="@+id/pairing_code"
                android:text="———"
                android:textColor="#f0dfa0"
                android:textSize="64sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Instructions -->
        <TextView
            android:text="Visit admin.venueos.jjjk.com.au"
            android:textColor="#9bab9f"
            android:textSize="14sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:text="go to Players and assign this display to a venue"
            android:textColor="#6c7d72"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Fullscreen WebView shown once display is assigned and running -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

</FrameLayout>
